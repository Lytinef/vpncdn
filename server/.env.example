# ── App ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Базовый публичный URL API (для вебхуков YooKassa)
PUBLIC_API_URL=https://api.example.com

# ── Database ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=vpn
DB_PASSWORD=vpn
DB_NAME=vpn

# ── Redis (очереди BullMQ, кэш) ─────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT (клиентские токены) ─────────────────────────
JWT_ACCESS_SECRET=change_me_access
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_TTL=2592000

# ── Telegram Login ──────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_BOT_USERNAME=my_vpn_bot
# Окно валидности подписи Telegram-логина (сек)
TELEGRAM_AUTH_TTL=86400

# ── YooKassa ────────────────────────────────────────
YOOKASSA_SHOP_ID=000000
YOOKASSA_SECRET_KEY=test_xxx
# URL, куда YooKassa шлёт уведомления о статусе платежа
YOOKASSA_WEBHOOK_PATH=/payments/yookassa/webhook
# Возврат пользователя после оплаты (deeplink клиента)
YOOKASSA_RETURN_URL=unway://payment/result

# ── Admin panel ─────────────────────────────────────
ADMIN_JWT_SECRET=change_me_admin
ADMIN_JWT_TTL=43200
# Начальный администратор (создаётся сидом)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change_me_now
# CORS для админки
ADMIN_ORIGIN=http://localhost:8080

# ── Xray node management ────────────────────────────
# Общий секрет для gRPC/HTTP API управления Xray-узлами
XRAY_API_SECRET=change_me_xray

# ── Алёрты нагрузки (Telegram) ──────────────────────
# chat_id, куда слать предупреждения о нагрузке узлов (пусто — выключено).
# Узнать свой id: напишите боту @userinfobot. Использует TELEGRAM_BOT_TOKEN выше.
ALERT_TELEGRAM_CHAT_ID=
# Пороги в процентах
ALERT_CPU_PERCENT=85
ALERT_MEM_PERCENT=90
