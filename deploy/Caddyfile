# Caddy: автоматический HTTPS (Let's Encrypt) для API и админки.

{
    email lytinef@gmail.com
    # Отключаем HTTP/3: udp/443 занят hysteria (прямой режим). Иначе Caddy
    # анонсирует Alt-Svc h3=":443", браузер идёт по HTTP/3 в hysteria → NetworkError.
    servers {
        protocols h1 h2
    }
}

# API backend
api.lytinef.ru {
    reverse_proxy server:3000
}

# Веб-админка (статика на nginx внутри контейнера admin)
admin.lytinef.ru {
    reverse_proxy admin:80
}
