# Переменные для deploy/docker-compose.prod.yml
POSTGRES_USER=vpn
POSTGRES_PASSWORD=ЗАМЕНИ_надёжный_пароль
POSTGRES_DB=vpn

# URL API, который зашивается в сборку админки (куда она ходит)
ADMIN_API_BASE_URL=https://api.example.com

# Секрет агента Xray-узла (тот же указывается в админке при добавлении узла).
# Сгенерировать: openssl rand -hex 24
AGENT_SECRET=ЗАМЕНИ_случайный_секрет
